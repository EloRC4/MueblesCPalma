# =============================================================================
# Environment variables for the production stack (docker-compose.prod.yml)
# Copy to ".env" and fill in before deploying:  cp .env.example .env
# =============================================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=muebles_cpalma_db
MYSQL_USER=cpalma_user
MYSQL_PASSWORD=change_me_app

# --- Web ---
# Host port where nginx exposes the application
WEB_PORT=80
