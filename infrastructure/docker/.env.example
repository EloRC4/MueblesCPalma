# =============================================================================
# Variables de entorno del stack de producción (docker-compose.prod.yml)
# Copiar a ".env" y rellenar antes de desplegar:  cp .env.example .env
# =============================================================================

# --- Base de datos ---
MYSQL_ROOT_PASSWORD=cambiame_root
MYSQL_DATABASE=muebles_cpalma_db
MYSQL_USER=cpalma_user
MYSQL_PASSWORD=cambiame_app

# --- Web ---
# Puerto del host en el que nginx expone la aplicación
WEB_PORT=80
