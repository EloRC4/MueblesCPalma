# =============================================================================
# Muebles C Palma - Global Git Ignore
# =============================================================================

# compiled cue and OS garbage
*.class
*.log
*.sh

*.ctxt
.DS_Store
.cfignore
Thumbs.db

# Maven packaging outputs (Java compile target)
backend/target/
backend/*.jar
backend/*.war

# IDE Specific metadata (IntelliJ, Eclipse, VS Code)
.idea/
*.iml
*.iws
.classpath
.project
.settings/
.vscode/
*.code-workspace
.factorypath

# Docker specific runtime exclusions
infrastructure/docker/mysql_data/
infrastructure/docker/db_data/
*.env

# Frontend / Node (For future phase)
node_modules/
frontend/dist/
frontend/.next/

# Frontend public images: ignore everything except the files the site
# actually needs to render correctly (referenced from code or database)
frontend-public/assets/*
frontend-public/images/*
!frontend-public/assets/mesa_main.jpg
!frontend-public/assets/mesa_det1.jpg
!frontend-public/assets/silla.jpg
!frontend-public/assets/sofa_main.jpg
!frontend-public/assets/sofa_det1.jpg
!frontend-public/images/Background-tile.png
!frontend-public/images/expo.jpg
!frontend-public/images/fachada.jpg
!frontend-public/images/salon.jpg
!frontend-public/images/silla_main.jpg
!frontend-public/images/sofa.jpg
